[Unit]
Description=AniGate local MCP gateway
After=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/anigate http --addr 127.0.0.1:8787 --config %h/.config/anigate/anigate.json
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
# Add operator or agent workspace directories here if your config needs writes.
ReadWritePaths=%h/.local/state/anigate %h/.config/anigate

[Install]
WantedBy=default.target
